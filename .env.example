# Per-merchant identity
XPAY_MERCHANT_SLUG=acme-outdoors
SITE_URL=https://store.acme.example/
SITE_NAME=Acme Outdoors
SITE_DESCRIPTION=Climbing gear and trail food

# Shared HS256 secret for cart-deeplink JWTs.
# Get this from your xpay merchant account: app.xpay.sh/onboard/commercetools
XPAY_API_KEY=xpay_live_REPLACE_ME

# commercetools Project credentials (use a Project-scoped OAuth client; minimum
# scopes for v0.1: view_products, manage_my_orders, manage_my_quotes,
# manage_my_payments, view_orders)
CTP_PROJECT_KEY=acme-outdoors-prod
CTP_CLIENT_ID=REPLACE
CTP_CLIENT_SECRET=REPLACE
CTP_SCOPES=view_products:acme-outdoors-prod manage_my_orders:acme-outdoors-prod
CTP_AUTH_URL=https://auth.us-central1.gcp.commercetools.com
CTP_API_URL=https://api.us-central1.gcp.commercetools.com

# Optional
HOST=0.0.0.0
PORT=8787
CHECKOUT_PATH=/checkout
EMIT_OAUTH_PROTECTED_RESOURCE=0
EMIT_AGENT_CARD=0
